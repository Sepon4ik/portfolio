# Публичный URL сайта (Open Graph, canonical, sitemap)
# Продакшен: https://portfolio-pavel-dranchuk.vercel.app (дублируется в .env.production)
NEXT_PUBLIC_SITE_URL=

# Имя бота без @ — для кнопки «Free Guide» (deep link в Telegram)
NEXT_PUBLIC_TG_GUIDE_BOT=

# Опционально: URL или путь к фоновому MP3 (по умолчанию /audio/ambience.mp3 в public/)
# NEXT_PUBLIC_AMBIENCE_AUDIO_SRC=/audio/ambience.mp3

# Опционально: Google Analytics 4 — ID вида G-XXXXXXXXXX (Vercel Analytics в коде уже включён)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
